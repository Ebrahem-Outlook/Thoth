{
  "Thoth": {
    "WorkspaceRoot": ".",
    "DataDirectory": "data",
    "MaxAgentSteps": 8,
    "Model": {
      "Provider": "self",
      "Model": "thoth-self",
      "Temperature": 0.2
    },
    "Sandbox": {
      "AllowFileWrites": true,
      "AllowShell": false,
      "ShellTimeoutSeconds": 20,
      "AllowedShellExecutables": [ "dotnet", "git", "rg" ],
      "BlockedCommandTokens": [ " rm ", " del ", " rmdir ", "format", "shutdown", "git reset", "git clean" ]
    }
  }
}
